#!/bin/bash
# Fetch application secret from AWS SSM Parameter Store
# Runs before service starts (ExecStartPre in systemd unit)
# Secrets fetched at startup, not stored permanently

set -e

REGION="{{ aws_region }}"
SECRET_NAME="/rewards/dev/secrets/APP_SECRET"
ENV_FILE="{{ app_dir }}/.env"

echo "Fetching secret from SSM Parameter Store..."

# Fetch secret with error handling
if ! SECRET_VALUE=$(aws ssm get-parameter \
  --name "$SECRET_NAME" \
  --with-decryption \
  --query 'Parameter.Value' \
  --output text \
  --region "$REGION" 2>&1); then
  echo "ERROR: Failed to fetch secret from SSM: $SECRET_VALUE"
  exit 1
fi

# Verify secret was retrieved
if [ -z "$SECRET_VALUE" ]; then
  echo "ERROR: Secret value is empty"
  exit 1
fi

# Write environment file
cat > "$ENV_FILE" << EOF
APP_SECRET=$SECRET_VALUE
AWS_REGION=$REGION
GIT_COMMIT={{ git_commit }}
EOF

# Secure permissions - only ec2-user can read
chown {{ app_user }}:{{ app_group }} "$ENV_FILE"
chmod 600 "$ENV_FILE"

echo "Secret successfully fetched and stored in $ENV_FILE"
